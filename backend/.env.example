# Finance Dashboard Backend — Environment Variables
# Copy this file to .env and fill in your values

# CoinGecko API key (get one free at https://www.coingecko.com/api/pricing)
# Demo keys start with CG-, Pro keys don't
COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxx

# Port for the Express server (Railway sets this automatically)
PORT=3000

# Your Vercel frontend URL (for CORS — use * to allow all origins)
FRONTEND_URL=https://your-app.vercel.app

# Directory for the SQLite database file
# On Railway: mount a volume at /data and set DATA_DIR=/data
# Locally: leave empty (uses ./data)
DATA_DIR=./data
